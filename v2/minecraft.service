[Unit]
Description=Minecraft Server
After=network-online.target

[Service]
Type=forking
User=minecraft
Group=minecraft
WorkingDirectory=/opt/minecraft

ExecStart=/bin/bash -c '/usr/bin/tmux new-session -d -s mc "java -jar server.jar nogui"'
ExecStop=/usr/bin/tmux send-keys -t mcserver stop Enter

Restart=on-failure
RestartSec=10

LimitNOFILE=65535
TimeoutStopSec=60

[Install]
WantedBy=multi-user.target