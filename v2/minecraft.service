[Unit]
Description=Minecraft Server
After=network-online.target

[Service]
Type=forking
User=minecraft
Group=minecraft
WorkingDirectory=/opt/minecraft

ExecStart=/bin/bash -c './control.sh start'
ExecStop=/bin/bash -c './control.sh stop'

Restart=on-failure
RestartSec=10

LimitNOFILE=65535
TimeoutStopSec=60

[Install]
WantedBy=multi-user.target